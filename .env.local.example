# Database
DATABASE_URL="postgresql://user:password@localhost:5432/streamify"
DIRECT_URL="postgresql://user:password@localhost:5432/streamify"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers
GITHUB_ID="your-github-id"
GITHUB_SECRET="your-github-secret"
GOOGLE_ID="your-google-id"
GOOGLE_SECRET="your-google-secret"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_xxx"
RAZORPAY_KEY_SECRET="xxx"
RAZORPAY_WEBHOOK_SECRET="xxx"

# AWS S3
NEXT_PUBLIC_AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="xxx"
AWS_SECRET_ACCESS_KEY="xxx"
AWS_S3_BUCKET="streamify-videos"
AWS_CLOUDFRONT_URL="https://d123.cloudfront.net"

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="xxx"
CLOUDINARY_API_KEY="xxx"
CLOUDINARY_API_SECRET="xxx"

# Email
RESEND_API_KEY="xxx"

# API Keys
ALGOLIA_APP_ID="xxx"
ALGOLIA_SEARCH_API_KEY="xxx"

# Environment
NODE_ENV="development"
