// Learn more about the structure: https://github.com/prisma/prisma-examples/tree/latest/databases/postgresql
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionPlan {
  FREE_TRIAL
  BASIC
  STANDARD
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED
}

enum ContentType {
  MOVIE
  SERIES
  ANIME
  KDRAMA
}

enum AgeRating {
  G
  PG
  PG_13
  R
  NC_17
}

enum DownloadStatus {
  PENDING
  COMPLETED
  EXPIRED
  FAILED
}

model User {
  id                    String @id @default(cuid())
  email                 String @unique
  passwordHash          String
  name                  String
  avatarUrl             String?
  role                  UserRole @default(USER)
  
  // Stripe
  stripeCustomerId      String? @unique
  subscriptionPlan      SubscriptionPlan @default(FREE_TRIAL)
  subscriptionStatus    SubscriptionStatus @default(ACTIVE)
  
  // Trial logic
  trialStart            DateTime?
  trialEnd              DateTime?
  trialUsed             Boolean @default(false)
  
  // Relations
  subscription          Subscription?
  favorites             Favorite[]
  planToWatch           PlanToWatch[]
  watchHistory          WatchHistory[]
  downloads             Download[]
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([email])
  @@index([stripeCustomerId])
}

model Content {
  id                    String @id @default(cuid())
  title                 String
  slug                  String @unique
  description           String
  type                  ContentType
  genres                String[] @default([])
  language              String @default("en")
  releaseYear           Int
  durationMins          Int
  imdbRating            Float?
  malRating             Float?
  
  // Media URLs
  posterUrl             String
  backdropUrl           String
  trailerUrl            String?
  
  // Content settings
  isPremium             Boolean @default(true)
  ageRating             AgeRating?
  
  // Relations
  episodes              Episode[]
  videoSources          VideoSource[]
  subtitles             Subtitle[]
  watchHistory          WatchHistory[]
  favorites             Favorite[]
  planToWatch           PlanToWatch[]
  downloads             Download[]
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([type])
  @@index([releaseYear])
  @@index([slug])
}

model Episode {
  id                    String @id @default(cuid())
  contentId             String
  content               Content @relation(fields: [contentId], onDelete: Cascade)
  
  season                Int
  episodeNumber         Int
  title                 String
  description           String?
  durationMins          Int
  thumbnailUrl          String?
  hlsUrl                String? // HLS manifest URL
  
  // Skip intro
  skipIntroStart        Int? // in seconds
  skipIntroEnd          Int? // in seconds
  
  // Relations
  watchHistory          WatchHistory[]
  subtitles             Subtitle[]
  downloads             Download[]
  
  createdAt             DateTime @default(now())

  @@unique([contentId, season, episodeNumber])
  @@index([contentId])
}

model VideoSource {
  id                    String @id @default(cuid())
  contentId             String
  content               Content @relation(fields: [contentId], onDelete: Cascade)
  
  quality               Int // 360, 480, 720, 1080, 2160
  hlsUrl                String
  fileSizeMb            Int
  language              String @default("en")
  isDubbed              Boolean @default(false)
  
  createdAt             DateTime @default(now())

  @@unique([contentId, quality, isDubbed])
  @@index([contentId])
}

model Subtitle {
  id                    String @id @default(cuid())
  contentId             String?
  content               Content? @relation(fields: [contentId], onDelete: Cascade)
  
  episodeId             String?
  episode               Episode? @relation(fields: [episodeId], onDelete: Cascade)
  
  language              String
  label                 String
  vttUrl                String
  
  createdAt             DateTime @default(now())

  @@index([contentId])
  @@index([episodeId])
}

model WatchHistory {
  id                    String @id @default(cuid())
  userId                String
  user                  User @relation(fields: [userId], onDelete: Cascade)
  
  contentId             String
  content               Content @relation(fields: [contentId], onDelete: Cascade)
  
  episodeId             String?
  episode               Episode? @relation(fields: [episodeId], onDelete: SetNull)
  
  progressSeconds       Int @default(0)
  completed             Boolean @default(false)
  watchedAt             DateTime @default(now())
  
  updatedAt             DateTime @updatedAt

  @@unique([userId, contentId, episodeId])
  @@index([userId])
  @@index([contentId])
}

model Favorite {
  id                    String @id @default(cuid())
  userId                String
  user                  User @relation(fields: [userId], onDelete: Cascade)
  
  contentId             String
  content               Content @relation(fields: [contentId], onDelete: Cascade)
  
  addedAt               DateTime @default(now())

  @@unique([userId, contentId])
  @@index([userId])
}

model PlanToWatch {
  id                    String @id @default(cuid())
  userId                String
  user                  User @relation(fields: [userId], onDelete: Cascade)
  
  contentId             String
  content               Content @relation(fields: [contentId], onDelete: Cascade)
  
  addedAt               DateTime @default(now())

  @@unique([userId, contentId])
  @@index([userId])
}

model Subscription {
  id                    String @id @default(cuid())
  userId                String @unique
  user                  User @relation(fields: [userId], onDelete: Cascade)
  
  stripeSubscriptionId  String @unique
  plan                  SubscriptionPlan
  status                SubscriptionStatus
  
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean @default(false)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([stripeSubscriptionId])
}

model Download {
  id                    String @id @default(cuid())
  userId                String
  user                  User @relation(fields: [userId], onDelete: Cascade)
  
  contentId             String
  content               Content @relation(fields: [contentId], onDelete: Cascade)
  
  episodeId             String?
  episode               Episode? @relation(fields: [episodeId], onDelete: SetNull)
  
  expiresAt             DateTime
  status                DownloadStatus @default(PENDING)
  fileUrl               String?
  
  createdAt             DateTime @default(now())

  @@index([userId])
  @@index([contentId])
}
